# Example secrets file for RO Production Dashboard
# Copy this to secrets.toml (without .example) and fill in your real values.
# NEVER commit secrets.toml to git.

[mssql]
# Use a dedicated READ-ONLY SQL login. No write permissions.
# Adjust SERVER, DATABASE, UID, PWD for your RO Writer environment.
# TrustServerCertificate=yes is common for internal/self-signed certs.
connection_string = "DRIVER={ODBC Driver 17 for SQL Server};SERVER=your-ro-writer-sql-server;DATABASE=YourROWriterDatabase;UID=ro_dashboard_readonly;PWD=YourStrongPasswordHere;TrustServerCertificate=yes"

# Optional: if you have a different base URL or other secrets
# [db2]
# api_key = "your-readonly-api-key-if-using-legacy-api-path"
